{
  "name": "ketoui",
  "version": "0.1.2",
  "description": "Ultra-lightweight, zero-dependency, Apple-inspired UI component library.",
  "author": "Devvrat Sharma",
  "license": "MIT",
  "keywords": [
    "ui",
    "css",
    "lightweight",
    "apple",
    "glassmorphism",
    "web-components",
    "no-dependencies",
    "vanilla",
    "dark-mode",
    "theming"
  ],
  "main": "dist/keto.js",
  "style": "dist/keto.min.css",
  "unpkg": "dist/keto.min.css",
  "jsdelivr": "dist/keto.min.css",
  "exports": {
    ".": {
      "default": "./dist/keto.js"
    },
    "./css": "./dist/keto.min.css",
    "./js": "./dist/keto.js",
    "./js/*": "./dist/js/*"
  },
  "scripts": {
    "build:css": "postcss src/keto.css -o dist/keto.min.css",
    "build:js": "terser src/keto.js -o dist/keto.js -c -m && mkdir -p dist/js && for f in src/js/*.js; do terser \"$f\" -o \"dist/js/$(basename $f)\" -c -m; done",
    "build": "mkdir -p dist && npm run build:css && npm run build:js",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "overrides": {
    "postcss-calc": "10.1.1"
  },
  "devDependencies": {
    "cssnano": "^7.1.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "terser": "^5.46.1"
  }
}
